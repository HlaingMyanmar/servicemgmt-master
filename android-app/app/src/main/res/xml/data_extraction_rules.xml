<?xml version="1.0" encoding="utf-8"?>
<!--
    Controls backup & device-transfer for Android 12+ (API 31+).
    Mirrors backup_rules.xml logic for newer Android versions.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="sharedpref" path="." />
        <exclude domain="database"   path="." />
        <exclude domain="cache"      path="." />
        <exclude domain="external"   path="." />
    </cloud-backup>
    <device-transfer>
        <exclude domain="sharedpref" path="." />
        <exclude domain="database"   path="." />
    </device-transfer>
</data-extraction-rules>
