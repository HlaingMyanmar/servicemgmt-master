<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports
    http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
  name="sale_standard"
  pageWidth="595" pageHeight="842"
  columnWidth="535" leftMargin="30" rightMargin="30" topMargin="20" bottomMargin="20"
  isFloatColumnFooter="true">

  <!-- Parameters -->
  <parameter name="COMPANY_NAME"    class="java.lang.String"/>
  <parameter name="COMPANY_ADDRESS" class="java.lang.String"/>
  <parameter name="COMPANY_PHONE"   class="java.lang.String"/>
  <parameter name="COMPANY_EMAIL"   class="java.lang.String"/>
  <parameter name="INVOICE_TITLE"   class="java.lang.String"/>
  <parameter name="FOOTER_NOTE"     class="java.lang.String"/>
  <parameter name="LOGO_BASE64"     class="java.lang.String"/>

  <parameter name="INVOICE_NO"      class="java.lang.String"/>
  <parameter name="INVOICE_DATE"    class="java.lang.String"/>
  <parameter name="DUE_DATE"        class="java.lang.String"/>
  <parameter name="PAYMENT_STATUS"  class="java.lang.String"/>

  <parameter name="CUSTOMER_NAME"   class="java.lang.String"/>
  <parameter name="CUSTOMER_PHONE"  class="java.lang.String"/>
  <parameter name="CUSTOMER_ADDR"   class="java.lang.String"/>
  <parameter name="CASHIER_NAME"    class="java.lang.String"/>
  <parameter name="REMARK"          class="java.lang.String"/>

  <parameter name="SUBTOTAL_STR"    class="java.lang.String"/>
  <parameter name="DISCOUNT_STR"    class="java.lang.String"/>
  <parameter name="NET_TOTAL_STR"   class="java.lang.String"/>
  <parameter name="PAID_STR"        class="java.lang.String"/>
  <parameter name="DUE_STR"         class="java.lang.String"/>

  <!-- Subreport parameters -->
  <parameter name="ITEMS_SOURCE"    class="net.sf.jasperreports.engine.JRDataSource"/>
  <parameter name="PAYMENT_SOURCE"  class="net.sf.jasperreports.engine.JRDataSource"/>
  <parameter name="ITEMS_SUBREPORT" class="net.sf.jasperreports.engine.JasperReport"/>
  <parameter name="PAYMENT_SUBREPORT" class="net.sf.jasperreports.engine.JasperReport"/>

  <title>
    <band height="110">
      <!-- Header background -->
      <rectangle>
        <reportElement x="0" y="0" width="535" height="70" backcolor="#1E3A5F" forecolor="#1E3A5F"/>
        <graphicElement><pen lineWidth="0"/></graphicElement>
      </rectangle>

      <!-- Logo placeholder box -->
      <rectangle>
        <reportElement x="4" y="6" width="58" height="58" backcolor="#FFFFFF" forecolor="#FFFFFF"/>
        <graphicElement><pen lineWidth="0"/></graphicElement>
      </rectangle>
      <textField isBlankWhenNull="true">
        <reportElement x="4" y="6" width="58" height="58"/>
        <textElement textAlignment="Center" verticalAlignment="Middle">
          <font fontName="DejaVu Sans" size="7" forecolor="#1E3A5F"/>
        </textElement>
        <textFieldExpression><![CDATA["LOGO"]]></textFieldExpression>
      </textField>

      <!-- Company name -->
      <textField isBlankWhenNull="true">
        <reportElement x="68" y="8" width="280" height="18"/>
        <textElement verticalAlignment="Middle">
          <font fontName="DejaVu Sans" size="13" isBold="true" forecolor="#FFFFFF"/>
        </textElement>
        <textFieldExpression><![CDATA[$P{COMPANY_NAME}]]></textFieldExpression>
      </textField>
      <!-- Company address -->
      <textField isBlankWhenNull="true">
        <reportElement x="68" y="28" width="280" height="12"/>
        <textElement><font fontName="DejaVu Sans" size="7" forecolor="#BFD7F5"/></textElement>
        <textFieldExpression><![CDATA[$P{COMPANY_ADDRESS}]]></textFieldExpression>
      </textField>
      <!-- Company contact -->
      <textField isBlankWhenNull="true">
        <reportElement x="68" y="42" width="280" height="12"/>
        <textElement><font fontName="DejaVu Sans" size="7" forecolor="#BFD7F5"/></textElement>
        <textFieldExpression><![CDATA[$P{COMPANY_PHONE} + ($P{COMPANY_EMAIL} != null && !$P{COMPANY_EMAIL}.isEmpty() ? "  |  " + $P{COMPANY_EMAIL} : "")]]></textFieldExpression>
      </textField>

      <!-- Invoice title -->
      <textField isBlankWhenNull="true">
        <reportElement x="360" y="10" width="171" height="20"/>
        <textElement textAlignment="Right">
          <font fontName="DejaVu Sans" size="16" isBold="true" forecolor="#FFFFFF"/>
        </textElement>
        <textFieldExpression><![CDATA[$P{INVOICE_TITLE} != null && !$P{INVOICE_TITLE}.isEmpty() ? $P{INVOICE_TITLE} : "SALES INVOICE"]]></textFieldExpression>
      </textField>

      <!-- Invoice No -->
      <staticText>
        <reportElement x="360" y="35" width="80" height="11"/>
        <textElement textAlignment="Right"><font fontName="DejaVu Sans" size="7" forecolor="#BFD7F5"/></textElement>
        <text><![CDATA[Invoice No:]]></text>
      </staticText>
      <textField isBlankWhenNull="true">
        <reportElement x="444" y="35" width="87" height="11"/>
        <textElement textAlignment="Right"><font fontName="DejaVu Sans" size="7" isBold="true" forecolor="#FFFFFF"/></textElement>
        <textFieldExpression><![CDATA[$P{INVOICE_NO}]]></textFieldExpression>
      </textField>

      <!-- Date -->
      <staticText>
        <reportElement x="360" y="48" width="80" height="11"/>
        <textElement textAlignment="Right"><font fontName="DejaVu Sans" size="7" forecolor="#BFD7F5"/></textElement>
        <text><![CDATA[Date:]]></text>
      </staticText>
      <textField isBlankWhenNull="true">
        <reportElement x="444" y="48" width="87" height="11"/>
        <textElement textAlignment="Right"><font fontName="DejaVu Sans" size="7" forecolor="#FFFFFF"/></textElement>
        <textFieldExpression><![CDATA[$P{INVOICE_DATE}]]></textFieldExpression>
      </textField>

      <!-- Divider -->
      <line>
        <reportElement x="0" y="72" width="535" height="1" forecolor="#BFDBFE"/>
      </line>

      <!-- Bill To / Cashier row -->
      <staticText>
        <reportElement x="0" y="76" width="60" height="10"/>
        <textElement><font fontName="DejaVu Sans" size="7" isBold="true" forecolor="#64748B"/></textElement>
        <text><![CDATA[BILL TO:]]></text>
      </staticText>
      <textField isBlankWhenNull="true">
        <reportElement x="60" y="76" width="200" height="10"/>
        <textElement><font fontName="DejaVu Sans" size="8" isBold="true"/></textElement>
        <textFieldExpression><![CDATA[$P{CUSTOMER_NAME}]]></textFieldExpression>
      </textField>
      <textField isBlankWhenNull="true">
        <reportElement x="60" y="88" width="200" height="10"/>
        <textElement><font fontName="DejaVu Sans" size="7" forecolor="#475569"/></textElement>
        <textFieldExpression><![CDATA[$P{CUSTOMER_PHONE}]]></textFieldExpression>
      </textField>

      <staticText>
        <reportElement x="360" y="76" width="80" height="10"/>
        <textElement textAlignment="Right"><font fontName="DejaVu Sans" size="7" isBold="true" forecolor="#64748B"/></textElement>
        <text><![CDATA[CASHIER:]]></text>
      </staticText>
      <textField isBlankWhenNull="true">
        <reportElement x="444" y="76" width="87" height="10"/>
        <textElement textAlignment="Right"><font fontName="DejaVu Sans" size="7"/></textElement>
        <textFieldExpression><![CDATA[$P{CASHIER_NAME}]]></textFieldExpression>
      </textField>
      <staticText>
        <reportElement x="360" y="88" width="80" height="10"/>
        <textElement textAlignment="Right"><font fontName="DejaVu Sans" size="7" isBold="true" forecolor="#64748B"/></textElement>
        <text><![CDATA[STATUS:]]></text>
      </staticText>
      <textField isBlankWhenNull="true">
        <reportElement x="444" y="88" width="87" height="10"/>
        <textElement textAlignment="Right"><font fontName="DejaVu Sans" size="7" isBold="true" forecolor="#16A34A"/></textElement>
        <textFieldExpression><![CDATA[$P{PAYMENT_STATUS}]]></textFieldExpression>
      </textField>
    </band>
  </title>

  <detail>
    <band height="8">
      <!-- Items subreport injected here via summary band -->
    </band>
  </detail>

  <summary>
    <band height="300" isSplitAllowed="true">

      <!-- Items subreport label -->
      <staticText>
        <reportElement x="0" y="0" width="535" height="13"/>
        <textElement><font fontName="DejaVu Sans" size="7" isBold="true" forecolor="#1E3A5F"/></textElement>
        <text><![CDATA[ITEMS]]></text>
      </staticText>
      <line>
        <reportElement x="0" y="13" width="535" height="1" forecolor="#BFDBFE"/>
      </line>

      <!-- Items subreport -->
      <subreport>
        <reportElement x="0" y="14" width="535" height="80" isRemoveLineWhenBlank="true"/>
        <dataSourceExpression><![CDATA[$P{ITEMS_SOURCE}]]></dataSourceExpression>
        <subreportExpression><![CDATA[$P{ITEMS_SUBREPORT}]]></subreportExpression>
      </subreport>

      <!-- Totals box -->
      <rectangle>
        <reportElement x="320" y="104" width="215" height="80" backcolor="#F8FAFC" forecolor="#E2E8F0"/>
        <graphicElement><pen lineWidth="0.5"/></graphicElement>
      </rectangle>

      <staticText>
        <reportElement x="328" y="110" width="110" height="12"/>
        <textElement><font fontName="DejaVu Sans" size="8" forecolor="#64748B"/></textElement>
        <text><![CDATA[Subtotal]]></text>
      </staticText>
      <textField isBlankWhenNull="true">
        <reportElement x="438" y="110" width="90" height="12"/>
        <textElement textAlignment="Right"><font fontName="DejaVu Sans" size="8"/></textElement>
        <textFieldExpression><![CDATA[$P{SUBTOTAL_STR}]]></textFieldExpression>
      </textField>

      <staticText>
        <reportElement x="328" y="124" width="110" height="12"/>
        <textElement><font fontName="DejaVu Sans" size="8" forecolor="#64748B"/></textElement>
        <text><![CDATA[Discount]]></text>
      </staticText>
      <textField isBlankWhenNull="true">
        <reportElement x="438" y="124" width="90" height="12"/>
        <textElement textAlignment="Right"><font fontName="DejaVu Sans" size="8" forecolor="#DC2626"/></textElement>
        <textFieldExpression><![CDATA[$P{DISCOUNT_STR}]]></textFieldExpression>
      </textField>

      <line>
        <reportElement x="328" y="138" width="197" height="1" forecolor="#CBD5E1"/>
      </line>

      <!-- Net total highlight -->
      <rectangle>
        <reportElement x="320" y="140" width="215" height="18" backcolor="#1E3A5F" forecolor="#1E3A5F"/>
        <graphicElement><pen lineWidth="0"/></graphicElement>
      </rectangle>
      <staticText>
        <reportElement x="328" y="143" width="110" height="12"/>
        <textElement><font fontName="DejaVu Sans" size="8" isBold="true" forecolor="#FFFFFF"/></textElement>
        <text><![CDATA[Total]]></text>
      </staticText>
      <textField isBlankWhenNull="true">
        <reportElement x="438" y="143" width="90" height="12"/>
        <textElement textAlignment="Right"><font fontName="DejaVu Sans" size="9" isBold="true" forecolor="#FFFFFF"/></textElement>
        <textFieldExpression><![CDATA[$P{NET_TOTAL_STR}]]></textFieldExpression>
      </textField>

      <staticText>
        <reportElement x="328" y="162" width="110" height="12"/>
        <textElement><font fontName="DejaVu Sans" size="8" forecolor="#64748B"/></textElement>
        <text><![CDATA[Paid]]></text>
      </staticText>
      <textField isBlankWhenNull="true">
        <reportElement x="438" y="162" width="90" height="12"/>
        <textElement textAlignment="Right"><font fontName="DejaVu Sans" size="8" forecolor="#16A34A"/></textElement>
        <textFieldExpression><![CDATA[$P{PAID_STR}]]></textFieldExpression>
      </textField>

      <staticText>
        <reportElement x="328" y="176" width="110" height="12"/>
        <textElement><font fontName="DejaVu Sans" size="8" forecolor="#64748B"/></textElement>
        <text><![CDATA[Balance Due]]></text>
      </staticText>
      <textField isBlankWhenNull="true">
        <reportElement x="438" y="176" width="90" height="12"/>
        <textElement textAlignment="Right"><font fontName="DejaVu Sans" size="8" isBold="true" forecolor="#DC2626"/></textElement>
        <textFieldExpression><![CDATA[$P{DUE_STR}]]></textFieldExpression>
      </textField>

      <!-- Payment history label -->
      <staticText>
        <reportElement x="0" y="104" width="310" height="13"/>
        <textElement><font fontName="DejaVu Sans" size="7" isBold="true" forecolor="#1E3A5F"/></textElement>
        <text><![CDATA[PAYMENT HISTORY]]></text>
      </staticText>
      <line>
        <reportElement x="0" y="117" width="310" height="1" forecolor="#E2E8F0"/>
      </line>

      <!-- Payment subreport -->
      <subreport>
        <reportElement x="0" y="118" width="310" height="60" isRemoveLineWhenBlank="true"/>
        <dataSourceExpression><![CDATA[$P{PAYMENT_SOURCE}]]></dataSourceExpression>
        <subreportExpression><![CDATA[$P{PAYMENT_SUBREPORT}]]></subreportExpression>
      </subreport>

      <!-- Remark -->
      <staticText>
        <reportElement x="0" y="200" width="60" height="12"/>
        <textElement><font fontName="DejaVu Sans" size="7" isBold="true" forecolor="#64748B"/></textElement>
        <text><![CDATA[Remark:]]></text>
      </staticText>
      <textField isBlankWhenNull="true" isStretchWithOverflow="true">
        <reportElement x="62" y="200" width="473" height="12"/>
        <textElement><font fontName="DejaVu Sans" size="7" forecolor="#475569"/></textElement>
        <textFieldExpression><![CDATA[$P{REMARK}]]></textFieldExpression>
      </textField>

      <!-- Signature blocks -->
      <staticText>
        <reportElement x="0" y="230" width="160" height="12"/>
        <textElement textAlignment="Center"><font fontName="DejaVu Sans" size="7" forecolor="#64748B"/></textElement>
        <text><![CDATA[Customer Signature]]></text>
      </staticText>
      <line>
        <reportElement x="0" y="228" width="160" height="1" forecolor="#CBD5E1"/>
      </line>

      <staticText>
        <reportElement x="375" y="230" width="160" height="12"/>
        <textElement textAlignment="Center"><font fontName="DejaVu Sans" size="7" forecolor="#64748B"/></textElement>
        <text><![CDATA[Authorized Signature]]></text>
      </staticText>
      <line>
        <reportElement x="375" y="228" width="160" height="1" forecolor="#CBD5E1"/>
      </line>

      <!-- Footer -->
      <line>
        <reportElement x="0" y="258" width="535" height="1" forecolor="#BFDBFE"/>
      </line>
      <textField isBlankWhenNull="true">
        <reportElement x="0" y="262" width="535" height="12"/>
        <textElement textAlignment="Center"><font fontName="DejaVu Sans" size="7" forecolor="#64748B"/></textElement>
        <textFieldExpression><![CDATA[$P{FOOTER_NOTE} != null && !$P{FOOTER_NOTE}.isEmpty() ? $P{FOOTER_NOTE} : "Thank you for your business!"]]></textFieldExpression>
      </textField>
    </band>
  </summary>

</jasperReport>
