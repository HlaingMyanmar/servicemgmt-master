<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports
    http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
  name="payment_subreport"
  pageWidth="340" pageHeight="842"
  columnWidth="340" leftMargin="0" rightMargin="0" topMargin="0" bottomMargin="0"
  isFloatColumnFooter="true">

  <field name="PAY_DATE"   class="java.lang.String"/>
  <field name="PAY_METHOD" class="java.lang.String"/>
  <field name="PAY_AMOUNT" class="java.lang.String"/>

  <columnHeader>
    <band height="16">
      <rectangle>
        <reportElement x="0" y="0" width="340" height="16" backcolor="#F1F5F9" forecolor="#E2E8F0"/>
        <graphicElement><pen lineWidth="0.5"/></graphicElement>
      </rectangle>
      <staticText>
        <reportElement x="4" y="2" width="130" height="12"/>
        <textElement><font fontName="DejaVu Sans" size="7" isBold="true" forecolor="#475569"/></textElement>
        <text><![CDATA[DATE]]></text>
      </staticText>
      <staticText>
        <reportElement x="134" y="2" width="106" height="12"/>
        <textElement><font fontName="DejaVu Sans" size="7" isBold="true" forecolor="#475569"/></textElement>
        <text><![CDATA[METHOD]]></text>
      </staticText>
      <staticText>
        <reportElement x="240" y="2" width="96" height="12"/>
        <textElement textAlignment="Right"><font fontName="DejaVu Sans" size="7" isBold="true" forecolor="#475569"/></textElement>
        <text><![CDATA[AMOUNT]]></text>
      </staticText>
    </band>
  </columnHeader>

  <detail>
    <band height="14">
      <textField isBlankWhenNull="true">
        <reportElement x="4" y="1" width="130" height="12"/>
        <textElement><font fontName="DejaVu Sans" size="8"/></textElement>
        <textFieldExpression><![CDATA[$F{PAY_DATE}]]></textFieldExpression>
      </textField>
      <textField isBlankWhenNull="true">
        <reportElement x="134" y="1" width="106" height="12"/>
        <textElement><font fontName="DejaVu Sans" size="8"/></textElement>
        <textFieldExpression><![CDATA[$F{PAY_METHOD}]]></textFieldExpression>
      </textField>
      <textField isBlankWhenNull="true">
        <reportElement x="240" y="1" width="96" height="12"/>
        <textElement textAlignment="Right"><font fontName="DejaVu Sans" size="8"/></textElement>
        <textFieldExpression><![CDATA[$F{PAY_AMOUNT}]]></textFieldExpression>
      </textField>
      <line>
        <reportElement x="0" y="13" width="340" height="1" forecolor="#F1F5F9"/>
      </line>
    </band>
  </detail>

</jasperReport>
